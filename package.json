{
  "name": "portfolio",
  "version": "1.0.0",
  "author": {
    "name": "Matias Galeano"
  },
  "homepage": "https://matiasgaleano.dev/",
  "repository": {
    "url": "https://github.com/matigaleanodev/portfolio"
  },
  "scripts": {
    "ng": "ng",
    "build:content": "node ./scripts/build-content.mjs",
    "build:release-manifest": "node ./scripts/build-release-manifest.mjs",
    "build:chat-knowledge-payload": "node ./scripts/build-chat-knowledge-payload.mjs",
    "start": "npm run build:content && ng serve",
    "build": "npm run build:content && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "serve:ssr:portfolio": "node dist/portfolio/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/common": "^21.1.3",
    "@angular/compiler": "^21.1.3",
    "@angular/core": "^21.1.3",
    "@angular/forms": "^21.1.3",
    "@angular/platform-browser": "^21.1.3",
    "@angular/platform-server": "21.1.3",
    "@angular/router": "^21.1.3",
    "@angular/ssr": "21.1.3",
    "express": "^5.1.0",
    "lucide-angular": "^0.563.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.3",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.2",
    "gray-matter": "^4.0.3",
    "jsdom": "^27.1.0",
    "marked": "^17.0.4",
    "postcss": "^8.5.3",
    "sanitize-html": "^2.17.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8"
  }
}
